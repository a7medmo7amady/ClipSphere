# =========================
# Core App Config
# =========================
PORT=5000
MONGODB_URI=mongodb://localhost:27017/clipsphere

JWT_SECRET=change_this_in_production
JWT_EXPIRES_IN=24h

# =========================
# Email
# =========================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
CLIENT_URL=http://localhost:3000
VERIFICATION_CODE_EXPIRES_IN=10

# =========================
# Google OAuth
# =========================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
BASE_URL=http://localhost:5000/api/auth/google/callback

# =========================
# Session
# =========================
SESSION_SECRET=generate_random_secret

# =========================
# Embeddings / Gemini Developer API
# =========================
EMBEDDINGS_MODE=strict

# Create a key in Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

VIDEO_EMBEDDING_VECTOR_LENGTH=768
MONGO_VIDEO_VECTOR_INDEX_NAME=videos_embedding_index

S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=videos
